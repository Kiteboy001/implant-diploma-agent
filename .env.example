# Implant Diploma Agent - Environment Variables
# Set these in Railway dashboard (or copy from your local .env)

# Provider API key (pick one that works)
DEEPSEEK_API_KEY=your_key_here

# Telegram (to let students chat via Telegram)
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_ALLOWED_USERS=*

# Gateway
GATEWAY_ALLOW_ALL_USERS=true
